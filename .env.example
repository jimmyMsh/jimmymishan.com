# Copy to .env on the VPS (and locally if needed). Never commit .env.
CERTBOT_EMAIL=you@example.com
DEPLOY_WEBHOOK_SECRET= # HMAC key for POST /api/deploys/webhook; unset disables the route (503)
GITHUB_USER=jimmyMsh # GitHub poller target for /api/github
SSE_MAX_CONNECTIONS=100 # global cap on concurrent /api/events connections
