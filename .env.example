# Copy to .env on the VPS (and locally if needed). Never commit .env.
CERTBOT_EMAIL=you@example.com
DEPLOY_WEBHOOK_SECRET= # HMAC key for POST /api/deploys/webhook; unset disables the route (503)
GITHUB_USER=jimmyMsh # GitHub poller target for /api/github
SSE_MAX_CONNECTIONS=100 # global cap on concurrent /api/events connections
GUESTBOOK_ENABLED=true # "true"/"false"; disables the guestbook route (503) when false
CONTACT_DISCORD_WEBHOOK= # Discord webhook URL for POST /api/contact; unset disables the route (503)
LOG_TAIL_ENABLED=true # "true"/"false"; disables the log tail listener and /api/logs (503) when false
LOG_TAIL_ALLOW_PRIVATE=false # "true"/"false"; keep false in prod, true for local/dev syslog testing
WRITE_SECRET= # HMAC key for write-path tokens/ip-hashing; unset generates a random per-boot secret
