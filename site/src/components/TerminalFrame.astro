---
interface Props {
  title?: string;
  decorative?: boolean;
}

const { title = "jimmy@jimmymishan.com: ~", decorative = false } = Astro.props;
const rootAttrs: { "aria-hidden"?: "true" } = decorative ? { "aria-hidden": "true" } : {};
---

<div class="terminal" {...rootAttrs}>
  <div class="terminal-bar">
    <span class="dot"></span>
    <span class="dot"></span>
    <span class="dot"></span>
    <span class="terminal-title">{title}</span>
  </div>
  <div class="terminal-body">
    <slot />
  </div>
</div>

<style>
  .terminal {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    overflow: hidden;
  }
  .terminal-bar {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-2) var(--space-3);
    border-bottom: 1px solid var(--color-border);
  }
  .dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: var(--color-border);
  }
  .terminal-title {
    margin-left: var(--space-2);
    color: var(--color-text-muted);
  }
  .terminal-body {
    padding: var(--space-4);
    line-height: 1.9;
  }
</style>
